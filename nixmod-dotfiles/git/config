# Git + delta config. Git reads ~/.config/git/config (XDG).
# See https://dandavison.github.io/delta/configuration.html

[user]
	name = nikitasmen
	email = menounosnikitas@gmail.com

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[merge]
	conflictStyle = zdiff3

[delta]
	navigate = true
	dark = true
	line-numbers = true
	side-by-side = true