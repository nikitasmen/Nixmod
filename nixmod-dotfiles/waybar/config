        "tooltip-format": "({used}/{total})({percentage_used}%) in '{path}', available {free}({percentage_free}%)",
        "states": {
            "high": 90,
            "upper-medium": 70,
            "medium": 50,
            "lower-medium": 30,
            "low": 10,
        },
        "on-click": "kitty -e btop",
        "on-click-right": "kitty -e btm",
    },

    "temperature": {
        "tooltip": false,
        "critical-threshold": 80,
        "format": "{icon}{temperatureC}σΑî³",
        "format-critical": "πüîΞ{icon}{temperatureC}σΑî³",
